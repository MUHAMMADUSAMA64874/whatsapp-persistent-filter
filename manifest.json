{
  "manifest_version": 3,
  "name": "WhatsApp Search Lock",
  "version": "1.0",
  "description": "Keeps WhatsApp Web search text persistent.",
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
